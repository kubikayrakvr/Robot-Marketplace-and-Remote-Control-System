# ====================================================
# RoboFleet — Ortam Değişkenleri (.env) Şablonu
# ====================================================
# Bu dosyayı .env olarak kopyalayın ve değişkenleri düzenleyin:
# cp .env.example .env

# ====================================================
# 📦 PostgreSQL Veritabanı Bağlantısı
# ====================================================
POSTGRES_USER=robofleet_user
POSTGRES_PASSWORD=SecurePassword123!
POSTGRES_DB=robofleet_db

# Docker ağı üzerinden veritabanına bağlanmak için:
DATABASE_URL=postgresql://robofleet_user:SecurePassword123!@db:5432/robofleet_db

# ====================================================
# 💾 Redis Bağlantısı (JWT Blacklist ve Rate Limiting)
# ====================================================
# Docker ağı üzerinden Redis host adıyla çözümlenir
REDIS_URL=redis://redis:6379/0

# ====================================================
# 🔐 JWT ve Güvenlik Ayarları
# ====================================================
# Güçlü bir gizli anahtar üretmek için:
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT token algoritması (RS256: Asimetrik şifreleme)
ALGORITHM=RS256

# Erişim tokenının geçerlilik süresi (dakika)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# RSA anahtarları (Docker başlangıçında otomatik üretilir)
# Manuel üretmek isterseniz:
# openssl genrsa -out private.pem 2048
# openssl rsa -in private.pem -pubout -out public.pem
PRIVATE_KEY_PATH=./private.pem
PUBLIC_KEY_PATH=./public.pem

# ====================================================
# 📡 ROS ve Simülasyon Bağlantıları
# ====================================================
# ROSBridge WebSocket sunucusu adresi
ROSBRIDGE_HOST=localhost
ROSBRIDGE_PORT=9090

# Web Video Server (Kamera akışı) adresi
WEB_VIDEO_SERVER_HOST=localhost
WEB_VIDEO_SERVER_PORT=8080

# ====================================================
# 🌐 CORS Ayarları (Frontend Erişim İzinleri)
# ====================================================
# Virgülle ayrılmış liste şeklinde izin verilen origin'ler
# Varsayılan: Yerel geliştirme ve test sunucusu
CORS_ORIGINS=http://localhost:5173,http://49.13.13.48:5173,http://49.13.13.48

# ====================================================
# 📊 Rate Limiting Ayarları
# ====================================================
# Dakika başına maksimum istek sayısı (0 = sınırsız)
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ====================================================
# 🛡️ Siber Güvenlik Ayarları
# ====================================================
# Başarısız giriş denemesi sonrasında hesap kilitlenme süresi (dakika)
LOGIN_ATTEMPT_LOCK_DURATION=15

# Maksimum başarısız giriş deneme sayısı
MAX_LOGIN_ATTEMPTS=5

# ====================================================
# 📧 E-posta Ayarları (İsteğe bağlı)
# ====================================================
# Şifre sıfırlama ve bildirim e-postaları için
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=noreply@robofleet.com

# ====================================================
# 🚀 Geliştirme Ayarları
# ====================================================
# Hata ayıklama modu (False = Üretim)
DEBUG=False

# Log seviyesi (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ====================================================
# 📝 Notlar
# ====================================================
# ⚠️ ÖNEMLİ: Üretim ortamında bu dosyayı git'e commit etmeyin!
# ⚠️ Tüm şifreleri güçlü ve benzersiz hale getirin.
# ⚠️ SECRET_KEY ve veritabanı şifrelerini her zaman değiştirin.
# ⚠️ CORS_ORIGINS ayarını yalnızca güvenli domain'lerle sınırlayın.
